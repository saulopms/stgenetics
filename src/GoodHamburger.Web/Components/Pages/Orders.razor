@page "/orders"
@attribute [Authorize]
@inject OrderApiClient OrderApi
@inject NavigationManager Nav

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>📋 Pedidos</h3>
    <a class="btn btn-dark" href="/orders/create">+ Novo Pedido</a>
</div>

@if (loading)
{
    <p><em>Carregando…</em></p>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (!orders.Any())
{
    <div class="alert alert-info">Nenhum pedido ainda. <a href="/orders/create">Criar um!</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Itens</th>
                    <th>Subtotal</th>
                    <th>Desconto</th>
                    <th>Total</th>
                    <th>Criado em</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in orders)
                {
                    <tr>
                        <td><code class="small">@o.Id.ToString()[..8]…</code></td>
                        <td>@string.Join(", ", o.Items.Select(i => i.MenuItemName))</td>
                        <td>R$ @o.Subtotal.ToString("F2")</td>
                        <td>
                            @if (o.DiscountPercentage > 0)
                            {
                                <span class="badge bg-success">-@((o.DiscountPercentage * 100).ToString("F0"))%</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td><strong>R$ @o.Total.ToString("F2")</strong></td>
                        <td class="text-muted small">@o.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-secondary me-1" href="/orders/@o.Id">Ver</a>
                            <a class="btn btn-sm btn-outline-primary me-1"   href="/orders/@o.Id/edit">Editar</a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ConfirmarExclusao(o.Id)">Excluir</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (deleteConfirmId.HasValue)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmar exclusão</h5>
                </div>
                <div class="modal-body">
                    Excluir o pedido <code>@deleteConfirmId.Value.ToString()[..8]…</code>?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarExclusao">Cancelar</button>
                    <button class="btn btn-danger"    @onclick="ExecutarExclusao">Excluir</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<OrderResponse> orders = [];
    private bool loading = true;
    private string? error;
    private Guid? deleteConfirmId;

    protected override async Task OnInitializedAsync() => await CarregarPedidos();

    private async Task CarregarPedidos()
    {
        loading = true;
        error   = null;
        try   { orders = await OrderApi.GetAllAsync() ?? []; }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private void ConfirmarExclusao(Guid id) => deleteConfirmId = id;
    private void CancelarExclusao()         => deleteConfirmId = null;

    private async Task ExecutarExclusao()
    {
        if (deleteConfirmId is null) return;
        try
        {
            await OrderApi.DeleteAsync(deleteConfirmId.Value);
            deleteConfirmId = null;
            await CarregarPedidos();
        }
        catch (Exception ex) { error = ex.Message; }
    }
}
