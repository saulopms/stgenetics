@page "/menu"
@attribute [Authorize]
@inject MenuApiClient MenuApi

<PageTitle>Cardápio — Good Hamburger</PageTitle>

<h3>🍔 Cardápio</h3>

@if (loading)
{
    <p><em>Carregando…</em></p>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="row g-3">
        <div class="col-12">
            <h5 class="text-muted">Sanduíches</h5>
        </div>
        @foreach (var item in sandwiches)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title fw-bold">@item.Name</h6>
                        <p class="card-text text-success fw-semibold">R$ @item.Price.ToString("F2")</p>
                        <span class="badge bg-secondary">@TraduzirTipo(item.Type)</span>
                    </div>
                </div>
            </div>
        }

        <div class="col-12 mt-3">
            <h5 class="text-muted">Acompanhamentos</h5>
        </div>
        @foreach (var item in sides)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title fw-bold">@item.Name</h6>
                        <p class="card-text text-success fw-semibold">R$ @item.Price.ToString("F2")</p>
                        <span class="badge bg-info text-dark">@TraduzirTipo(item.Type)</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 p-3 bg-light rounded">
        <h6>Regras de desconto</h6>
        <ul class="mb-0">
            <li>Sanduíche + Batata Frita + Refrigerante → <strong>20% de desconto</strong></li>
            <li>Sanduíche + Refrigerante → <strong>15% de desconto</strong></li>
            <li>Sanduíche + Batata Frita → <strong>10% de desconto</strong></li>
        </ul>
    </div>
}

@code {
    private List<MenuItemResponse> sandwiches = [];
    private List<MenuItemResponse> sides      = [];
    private bool loading = true;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await MenuApi.GetMenuAsync() ?? [];
            sandwiches = items.Where(i => i.Type == "Sandwich").ToList();
            sides      = items.Where(i => i.Type != "Sandwich").ToList();
        }
        catch (Exception ex)
        {
            error = $"Falha ao carregar cardápio: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private static string TraduzirTipo(string type) => type switch
    {
        "Sandwich" => "Sanduíche",
        "Fries"    => "Batata Frita",
        "Soda"     => "Refrigerante",
        _          => type
    };
}
